{
    "name": "sheenazien8/bluetooth-devices",
    "description": "A plugin that can fetch bluetooth devices for you nativephp",
    "type": "nativephp-plugin",
    "license": "MIT",
    "version": "1.0.0",
    "authors": [
        {
            "name": "Your Name",
            "email": "you@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "nativephp/mobile": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Sheenazien8\\BluetoothDevices\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Sheenazien8\\BluetoothDevices\\BluetoothDevicesServiceProvider"
            ]
        },
        "nativephp": {
            "manifest": "nativephp.json"
        }
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
